# Fixture mode is the safe default and requires no external credentials.
DATA_MODE=fixture
ANALYSIS_MODE=fixture
REALCART_API_HOST=127.0.0.1
REALCART_API_PORT=8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
REALCART_API_PUBLIC_BASE_URL=http://127.0.0.1:8000
REALCART_WEB_PUBLIC_BASE_URL=http://localhost:3000
REALCART_ASSET_DIR=private-data/assets

# Required only for ANALYSIS_MODE=agents. Fixture analysis needs no key.
OPENAI_API_KEY=
TAGGER_MODEL=gpt-5.6-terra
SYNTHESIS_MODEL=gpt-5.6-sol
TAGGER_REASONING_EFFORT=low
SYNTHESIS_REASONING_EFFORT=medium
IMAGE_GENERATION_MODE=fixture
IMAGE_MODEL=gpt-image-2

# Traces are enabled, but prompt/output contents are excluded by default.
OPENAI_TRACING_ENABLED=true
OPENAI_TRACE_INCLUDE_SENSITIVE_DATA=false

# Optional live connectors. Do not commit real values or OAuth tokens.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/gmail/callback
GMAIL_ACCESS_TOKEN=
GMAIL_MAX_MESSAGES=12
GMAIL_PURCHASE_QUERY=newer_than:1y (subject:(order OR receipt OR shipped OR delivered OR return OR refund))
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://127.0.0.1:8000/api/auth/pinterest/callback
PINTEREST_ACCESS_TOKEN=
PINTEREST_API_BASE_URL=https://api-sandbox.pinterest.com/v5
PINTEREST_MAX_PINS=16
