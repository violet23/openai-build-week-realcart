# Fixture mode is the safe default and requires no external credentials.
DATA_MODE=fixture
ANALYSIS_MODE=fixture
REALCART_API_HOST=127.0.0.1
REALCART_API_PORT=8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Required only for ANALYSIS_MODE=agents. Fixture analysis needs no key.
OPENAI_API_KEY=
TAGGER_MODEL=gpt-5.6-terra
SYNTHESIS_MODEL=gpt-5.6-sol
TAGGER_REASONING_EFFORT=low
SYNTHESIS_REASONING_EFFORT=medium

# Traces are enabled, but prompt/output contents are excluded by default.
OPENAI_TRACING_ENABLED=true
OPENAI_TRACE_INCLUDE_SENSITIVE_DATA=false

# Optional live connectors. Do not commit real values or OAuth tokens.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
